# Copy to .env.local inside synago/ and poimen/ (each app reads its own env).
# Both apps must point at the SAME database.

# Postgres connection string (Supabase, Neon, RDS, or local Postgres).
# Tables are created and seeded automatically on first API request
# (see db/src/database.ts), or run lfc-demo-schema.sql once by hand.
DATABASE_URL=postgres://user:password@host:5432/dbname

# Cloudflare R2 (S3-compatible) storage for photo uploads
# (premobilisation, vehicle, and midweek service pictures).
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=your-bucket
# Public base URL the bucket is served from (custom domain or r2.dev URL)
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev
