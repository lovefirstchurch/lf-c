{
  "name": "lf-c-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "synago",
    "poimen",
    "db",
    "shared"
  ],
  "scripts": {
    "dev:synago": "npm run dev --workspace=@lfc/synago",
    "dev:poimen": "npm run dev --workspace=@lfc/poimen",
    "build:synago": "npm run build --workspace=@lfc/synago",
    "build:poimen": "npm run build --workspace=@lfc/poimen",
    "build": "npm run build --workspaces --if-present"
  }
}
